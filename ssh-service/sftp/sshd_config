# SFTP-Only SSH Server Configuration
# 只允许 SFTP 访问，禁止所有其他 SSH 功能

# 基本设置
Port 22
Protocol 2
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key

# 日志设置
SyslogFacility AUTH
LogLevel INFO

# 认证设置
PermitRootLogin no
PubkeyAuthentication yes
PasswordAuthentication no
PermitEmptyPasswords no
ChallengeResponseAuthentication no

# 禁用 PAM
UsePAM no

# 严格模式
StrictModes yes

# 禁用所有转发和隧道功能
AllowTcpForwarding no
X11Forwarding no
AllowAgentForwarding no
PermitTunnel no

# 禁用 TTY
PermitTTY no

# 禁用用户环境
PermitUserEnvironment no

# 只允许 SFTP 子系统
Subsystem sftp internal-sftp

# 针对 uploaduser 的特殊配置
Match User uploaduser
    # 强制只能使用 SFTP 内部服务器
    ForceCommand internal-sftp
    # 限制目录访问 - chroot 到用户家目录
    ChrootDirectory /home/uploaduser
    # 禁止所有转发
    AllowTcpForwarding no
    X11Forwarding no
    AllowAgentForwarding no
    PermitTunnel no
    # 禁止 TTY
    PermitTTY no
